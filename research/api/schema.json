{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Incident Object (MVP)",
  "type": "object",
  "properties": {
    "incident_id": { "type": "string" },
    "incident_type": { "type": "string" },
    "actor": { "type": "string" },
    "timestamp_start": { "type": "string", "format": "date-time" },
    "timestamp_end": { "type": "string", "format": "date-time" },
    "severity": { "type": "string", "enum": ["low", "medium", "high"] },
    "rule_score": { "type": "number" },
    "final_risk_score": { "type": "number" },
    "triggered_features": {
      "type": "array",
      "items": { "type": "string" }
    },
    "explanation": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "recommendation": { "type": "string" }
      },
      "required": ["summary"]
    },
    "evidence": {
      "type": "object",
      "properties": {
        "access_denied_count": { "type": "number" },
        "window_seconds": { "type": "number" },
        "top_event_names": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "required": [
    "incident_id",
    "incident_type",
    "actor",
    "timestamp_start",
    "timestamp_end",
    "severity",
    "rule_score",
    "final_risk_score",
    "triggered_features",
    "explanation"
  ]
}
