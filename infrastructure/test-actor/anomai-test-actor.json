{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SafeNoisyReadCalls",
      "Effect": "Allow",
      "Action": [
        "sts:GetCallerIdentity",
        "ec2:Describe*",
        "iam:List*",
        "iam:GetAccountSummary",
        "s3:ListAllMyBuckets"
      ],
      "Resource": "*"
    },
    {
      "Sid": "OptionalS3NoiseInYourBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::anomai-cloudtrail-logs-dev"
    }
  ]
}
